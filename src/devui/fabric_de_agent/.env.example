# DevUI agent environment (example)
# Copy to: src/devui/fabric_de_agent/.env

# MCP server URL for this repo's Fabric tools (Streamable HTTP). Use the deployed
# Container App URL, or if running locally, start the MCP server first and use the
# local URL.
# FABRIC_DE_MCP_SERVER_URL=http://127.0.0.1:8000/mcp

# Optional: a SECOND MCP server URL (if you have another MCP endpoint exposing
# OTHER_MCP_SERVER_URL=http://127.0.0.1:9000/mcp

# --- Model configuration (choose one approach) ---

# Option A: Azure AI Foundry Project (recommended if your endpoint looks like *.services.ai.azure.com)
# AZURE_AI_PROJECT_ENDPOINT=https://<your-foundry-project>.services.ai.azure.com
# AZURE_AI_MODEL_DEPLOYMENT_NAME=<your-model-deployment>

# Option B: Direct Azure OpenAI (endpoint should look like *.openai.azure.com)
# AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
# AZURE_OPENAI_CHAT_DEPLOYMENT_NAME=<your-deployment>
# Optional (if not using Azure identity):
# AZURE_OPENAI_API_KEY=<your-api-key>
# Optional:
# AZURE_OPENAI_API_VERSION=2024-10-21
